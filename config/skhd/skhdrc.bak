# applications
cmd - e : /usr/bin/open -a "Finder"
cmd - b : /usr/bin/open -a Safari
cmd - return         : /usr/bin/open -a Ghostty
cmd + shift - i : /usr/bin/open -a "iPhone Mirroring"

# window focus
alt - h : /opt/homebrew/bin/yabai -m window --focus west
alt - l : /opt/homebrew/bin/yabai -m window --focus east
alt - j : /opt/homebrew/bin/yabai -m window --focus south
alt - k : /opt/homebrew/bin/yabai -m window --focus north

# window move
shift + alt - h : /opt/homebrew/bin/yabai -m window --swap west
shift + alt - l : /opt/homebrew/bin/yabai -m window --swap east
shift + alt - j : /opt/homebrew/bin/yabai -m window --swap south
shift + alt - k : /opt/homebrew/bin/yabai -m window --swap east

# window resize
ctrl + alt - h : /opt/homebrew/bin/yabai -m window --resize right:-50:0
ctrl + alt - l : /opt/homebrew/bin/yabai -m window --resize right:50:0
ctrl + alt - j : /opt/homebrew/bin/yabai -m window --resize bottom:0:50
ctrl + alt - k : /opt/homebrew/bin/yabai -m window --resize bottom:0:-50

# window snap
cmd + shift - h  : /opt/homebrew/bin/yabai -m window --grid 1:2:0:0:1:1
cmd + shift - l : /opt/homebrew/bin/yabai -m window --grid 1:2:1:0:1:1
cmd + shift - f : /opt/homebrew/bin/yabai -m window --grid 1:1:0:0:1:1  # fullscreen
cmd + shift - c : /opt/homebrew/bin/yabai -m window --grid 40:40:1:1:38:38 # center

cmd - 1 : /opt/homebrew/bin/yabai -m space --focus 1
cmd - 2 : /opt/homebrew/bin/yabai -m space --focus 2
cmd - 3 : /opt/homebrew/bin/yabai -m space --focus 3
cmd - 4 : /opt/homebrew/bin/yabai -m space --focus 4
cmd - 5 : /opt/homebrew/bin/yabai -m space --focus 5
cmd - 6 : /opt/homebrew/bin/yabai -m space --focus 6
cmd - 7 : /opt/homebrew/bin/yabai -m space --focus 7
cmd - 8 : /opt/homebrew/bin/yabai -m space --focus 8
cmd - 9 : /opt/homebrew/bin/yabai -m space --focus 9
cmd - 0 : /opt/homebrew/bin/yabai -m space --focus 10

# window move to space
cmd + shift - 0x17 : /opt/homebrew/bin/yabai -m window --space 1
cmd + shift - 0x1C : /opt/homebrew/bin/yabai -m window --space 2
cmd + shift - 0x15 : /opt/homebrew/bin/yabai -m window --space 3
cmd + shift - 0x19 : /opt/homebrew/bin/yabai -m window --space 4
cmd + shift - 0x14 : /opt/homebrew/bin/yabai -m window --space 5
cmd + shift - 0x1D : /opt/homebrew/bin/yabai -m window --space 6
cmd + shift - 0x13 : /opt/homebrew/bin/yabai -m window --space 7
cmd + shift - 0x1B : /opt/homebrew/bin/yabai -m window --space 8
cmd + shift - 0x16 : /opt/homebrew/bin/yabai -m window --space 9
cmd + shift - 0x1C : /opt/homebrew/bin/yabai -m window --space 10

# window toggle
alt - f : /opt/homebrew/bin/yabai -m window --toggle float
alt - z : /opt/homebrew/bin/yabai -m window --toggle zoom-fullscreen
